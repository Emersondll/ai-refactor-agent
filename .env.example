# ── Anthropic (opcional — necessário apenas se USE_CLAUDE_FALLBACK=true) ──
ANTHROPIC_API_KEY=

# ── GitHub (necessário para COMMIT_PUSH ao final do pipeline) ──
GITHUB_TOKEN=
GITHUB_USERNAME=

# ── Modelos Ollama (valores padrão do config.py) ──
# MODEL_DOC=neural-chat:7b
# MODEL_STRUCT=qwen2.5-coder:7b
# MODEL_CLEAN=gemma4:latest
# MODEL_SOLID=qwen2.5-coder:14b
# MODEL_RECOVERY=gemma4:latest
# OLLAMA_BASE_URL=http://localhost:11434

# ── Flags de execução ──
USE_CLAUDE_FALLBACK=false
USE_AGENT_MODE=false
AGENT_MAX_CYCLES=20
PLANNER_MODE=local

# ── Features opcionais (desativadas por padrão) ──
USE_LLMLINGUA=false
USE_RAG_CONTEXT=false
USE_MEM0=false
USE_CONTEXT7=false
