# ── Anthropic (optional — required only if USE_CLAUDE_FALLBACK=true) ──
ANTHROPIC_API_KEY=

# ── GitHub (required for COMMIT_PUSH at the end of the pipeline) ──
GITHUB_TOKEN=
GITHUB_USERNAME=

# ── Refactoring Report ──
# GitHub URL of the repository being refactored.
# Shown in the header of refactoring_report.md committed inside the target repo.
# Example: REPO_GITHUB_URL=https://github.com/emersonlima/card-transaction-authorizer
REPO_GITHUB_URL=

# ── Ollama Models (config.py defaults) ──
# MODEL_DOC=qwen2.5-coder:7b
# MODEL_STRUCT=qwen2.5-coder:7b
# MODEL_CLEAN=gemma4:latest
# MODEL_SOLID=qwen2.5-coder:14b
# MODEL_RECOVERY=qwen2.5-coder:14b
# OLLAMA_BASE_URL=http://localhost:11434

# ── Execution flags ──
USE_CLAUDE_FALLBACK=false
USE_AGENT_MODE=false
AGENT_MAX_CYCLES=20
PLANNER_MODE=local

# ── Optional features (disabled by default) ──
USE_LLMLINGUA=false
USE_RAG_CONTEXT=false
USE_MEM0=false
USE_CONTEXT7=false
